#!name=哔哩哔哩Lite去广告@ddgksf2013
#!desc=轻量版去广告
#!category=ddgksf2013
#!author=ddgksf2013

[URL Rewrite]
^https?:\/\/app\.bilibili\.com\/x\/v2\/splash\/show - reject-200

[Script]
bilibili.ads = type=http-response, pattern=^https:\/\/app\.bilibili\.com\/x\/v2\/splash\/list, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/v2\/account\/myinfo\?, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/v2\/feed\/index, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/resource\/show\/tab, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/v2\/account\/mine, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/resource\/top\/activity, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60
bilibili.ads = type=http-response, pattern=^https?:\/\/app\.bilibili\.com\/x\/v2\/search\/square, script-path=https://cdn.jsdmirror.com/gh/5q68fs6b86-netizen/BiliBiliAdsLite@main/bilibili.ads.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% app.bilibili.com
